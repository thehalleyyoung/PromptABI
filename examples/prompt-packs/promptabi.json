{
  "name": "prompt-pack-support-contract",
  "checks": ["prompt-pack-contracts"],
  "artifacts": {
    "support-pack": {
      "kind": "prompt-pack",
      "path": "support.prompt-pack.json",
      "version": "1.0.0"
    },
    "messages": {
      "kind": "prompt-segment",
      "uri": "memory://prompt-pack/messages",
      "segments": [
        { "name": "system-policy", "role": "system", "required": true, "token_count": 12 },
        { "name": "retrieval-context", "role": "retrieval", "token_count": 18, "max_tokens": 32, "chunk_id": "kb:refund-policy", "citation": "kb/refunds" },
        { "name": "user-request", "role": "user", "required": true, "token_count": 10 },
        { "name": "assistant-answer", "role": "assistant", "token_count": 6 }
      ]
    },
    "budget": {
      "kind": "framework-truncation-config",
      "uri": "memory://prompt-pack/budget",
      "framework": "custom-rag-pipeline",
      "strategy": "priority",
      "max_context_tokens": 96,
      "drop_roles": ["retrieval"],
      "preserve_system": true
    },
    "tools": {
      "kind": "tool-definition",
      "uri": "memory://prompt-pack/tools",
      "provider": "openai",
      "tool_names": ["refund_user"]
    },
    "stops": {
      "kind": "stop-policy",
      "uri": "memory://prompt-pack/stops",
      "stop_sequences": ["</tool_call>"]
    },
    "provider": {
      "kind": "provider-config",
      "uri": "memory://prompt-pack/provider",
      "provider": "openai-compatible"
    }
  }
}
