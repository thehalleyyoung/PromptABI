{
  "name": "token-budget-demo",
  "checks": ["token-budget-model"],
  "max_context_tokens": 128,
  "artifacts": {
    "segments": {
      "kind": "prompt-segment",
      "path": "segments.json",
      "segments": [
        {
          "name": "system-policy",
          "role": "system",
          "must_survive": true,
          "token_count": 54,
          "overhead_tokens": 2
        },
        {
          "name": "retrieval-context",
          "role": "user",
          "required": false,
          "max_tokens": 40
        },
        {
          "name": "user-request",
          "role": "user",
          "required": true,
          "token_count": 18
        }
      ]
    },
    "runtime-budget": {
      "kind": "framework-truncation-config",
      "path": "runtime-budget.json",
      "framework": "vllm",
      "strategy": "left",
      "model": "demo-8b-instruct",
      "max_context_tokens": 96,
      "reserve_output_tokens": 20,
      "reserved_tool_tokens": 8,
      "generation_prompt_tokens": 3,
      "special_token_overhead": 5
    }
  }
}
