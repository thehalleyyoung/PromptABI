{
  "name": "end-to-end-training-quickstart-buggy",
  "checks": ["static-contracts", "training-packing", "training-redaction"],
  "artifacts": {
    "serving-template": {
      "kind": "chat-template",
      "path": "tokenizer_config.json",
      "roles": ["system", "user", "assistant"],
      "source": "end-to-end-training-quickstart",
