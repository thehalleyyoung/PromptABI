{
  "name": "end-to-end-structured-output-fixed",
  "checks": ["parser-compatibility"],
  "artifacts": {
    "answer-schema": {
      "kind": "schema",
      "path": "answer.schema.json",
      "dialect": "json-schema",
      "source": "end-to-end-structured-output",
      "metadata": {
        "parser_format": "json-schema",
        "parser_compatibility": {
          "accepts": ["{\"answer\":\"ok\",\"confidence\":\"high\"}"],
          "rejects": ["{}", "{\"answer\":\"ok\"}"]
        }
      }
    }
  }
}

