{
  "provider": "openai-compatible",
  "request_shape": {"messages": "array", "tools": "array"},
  "response_shape": {"tool_calls": "array"},
  "streaming_deltas": {"tool_calls": "array"},
  "tool_serialization": {
    "request": {
      "tool_names": ["lookup_order", "refund_order"],
      "argument_encoding": "json-object",
      "supports_parallel_tool_calls": false
    },
    "response": {
      "tool_names": ["lookup_order", "refund_order"],
      "argument_encoding": "json-object",
      "argument_escaping": "json",
      "observed_parallel_tool_calls": false,
      "tool_call_id_path": "choices[].message.tool_calls[].id"
    },
    "parser": {
      "accepted_tool_names": ["lookup_order", "refund_order"],
      "argument_encoding": "json-object",
      "require_tool_call_id": false,
      "allow_parallel_tool_calls": false,
      "streaming_mode": "complete-message"
    },
    "streaming": {
      "emits_argument_fragments": false
    }
  }
}

