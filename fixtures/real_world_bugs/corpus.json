{
  "version": 1,
  "methodology": "Public GitHub reports are reduced to synthetic tokenizer/template/stop/schema/tool fixtures that preserve the interface failure without copying upstream code.",
  "role_boundary_cases": [
    {
      "id": "phi_system_turn_forgery",
      "public_reference": "https://github.com/ggml-org/llama.cpp/pull/18462",
      "bug_class": "attacker-controlled content can render Phi-style role delimiters as structural turns",
      "template_config": {
        "chat_template": "{% for message in messages %}<|{{ message['role'] }}|>\n{{ message['content'] }}<|end|>\n{% endfor %}{% if add_generation_prompt %}<|assistant|>\n{% endif %}",
        "eos_token": "<|end|>",
        "additional_special_tokens": [
          "<|system|>",
          "<|user|>",
          "<|assistant|>",
          "<|end|>"
        ]
      },
      "expected_witnesses": [
        ["{messages[0].role}", "assistant", "role-header"],
        ["{messages[0].content}", "<|system|>", "special-token"],
        ["{messages[0].content}", "<|user|>", "special-token"],
        ["{messages[0].content}", "<|end|>", "special-token"]
      ]
    }
  ],
  "stop_overreachability_cases": [
    {
      "id": "qwen3_xml_tool_parameter_stop",
      "public_reference": "https://github.com/vllm-project/vllm/pull/40861",
      "bug_class": "XML-like tool-call delimiter appears as literal text inside a free-form tool parameter",
      "stop_sequences": ["</tool_call>", "</function>", "</parameter>"],
      "artifact_kind": "tool-definition",
      "artifact_json": [
        {
          "type": "function",
          "function": {
            "name": "run_code",
            "parameters": {
              "type": "object",
              "required": ["source"],
              "properties": {
                "source": {
                  "type": "string",
                  "description": "Source code or documentation may mention XML-like tags."
                }
              },
              "additionalProperties": false
            }
          }
        }
      ],
      "expected_findings": [
        {
          "stop_sequence": "</tool_call>",
          "category": "content",
          "region_kind": "tool-arguments-json",
          "parser_state_contains": "$.source"
        },
        {
          "stop_sequence": "</tool_call>",
          "category": "content",
          "region_kind": "xml-tool-call-content",
          "parser_state_contains": "$.source"
        }
      ]
    },
    {
      "id": "gemma4_quote_sentinel_truncation",
      "public_reference": "https://github.com/vllm-project/vllm/issues/39069",
      "bug_class": "custom quote sentinel decodes to a raw quote that can terminate parsing inside a string value",
      "stop_sequences": ["\""],
      "artifact_kind": "schema",
      "artifact_json": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "expected_findings": [
        {
          "stop_sequence": "\"",
          "category": "content",
          "region_kind": "json-schema-string",
          "parser_state_contains": "$.content"
        }
      ]
    },
    {
      "id": "llama_cpp_tool_call_parser_boundary",
      "public_reference": "https://github.com/ggml-org/llama.cpp/pull/20660",
      "bug_class": "tool-call close marker can be treated as a stop before downstream parser state is safe",
      "stop_sequences": ["</tool_call>"],
      "artifact_kind": "builtin-structural",
      "expected_findings": [
        {
          "stop_sequence": "</tool_call>",
          "category": "structural",
          "region_kind": "xml-tool-call",
          "parser_state_contains": "XML-like tool-call envelope"
        }
      ]
    }
  ]
}
