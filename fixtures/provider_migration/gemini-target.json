{
  "provider": "gemini",
  "request_shape": {"contents": "array", "tools": "array"},
  "response_shape": {"candidates": "array"},
  "streaming_deltas": {"candidates": "array"},
  "migration_compatibility": {
    "provider_family": "gemini",
    "request": {"required_fields": ["contents", "model", "tools", "response_schema"]},
    "response": {"required_fields": ["candidates", "finish_reason", "usage"]},
    "tools": {"argument_encoding": "json-object", "id_path": "candidates[].content.parts[].functionCall.id", "supports_parallel_tool_calls": false},
    "streaming": {"emits_argument_fragments": false},
    "stops": {"sequences": ["STOP"]},
    "limits": {"max_input_tokens": 1048576, "max_output_tokens": 8192},
    "structured_outputs": {"modes": ["response_schema"]},
    "errors": {"code_path": "error.status", "rate_limit_path": "error.status"}
  }
}
