      "labels": ["tokenizer", "normalization", "special-token"],
      "expected_rule_ids": ["tokenizer-differential-mismatch"],
      "replay": {
        "method": "tokenizer-differential",
        "text": " Cafe\u0301<tool><eos> ",
        "normalization": ["strip", "nfc"],
        "added_tokens": ["<tool>", "<eos>"],
        "special_tokens": {"<eos>": 2},
        "expected_token_ids": [67, 97, 102, 101, 256, 2],
        "expected_decoded_text": "Cafe<tool><eos>"
      }
    },
