    },
    {
      "id": "custom-rag-priority",
      "framework": "custom-rag",
      "policy": {
        "framework": "custom-rag-pipeline",
        "strategy": "priority",
        "drop_roles": ["retrieval"],
        "preserve_system": true,
        "max_context_tokens": 55
      },
      "segments": [
        {"name": "system-policy", "role": "system", "required": true, "token_count": 15},
        {"name": "retrieval-a", "role": "retrieval", "required": false, "token_count": 30},
        {"name": "retrieval-b", "role": "retrieval", "required": false, "token_count": 20},
        {"name": "question", "role": "user", "required": true, "token_count": 14}
      ],
      "expected": {
        "strategy": "priority",
        "kept": ["system-policy", "retrieval-b", "question"],
        "dropped": ["retrieval-a"],
        "must_survive_status": "proven",
        "rule_ids": ["token-budget-total-overflow", "token-budget-framework-truncation"]
      },
      "evidence": "Custom RAG policy drops retrieval context before required prompt regions."
    }
  ]
}
